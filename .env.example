# Database (для Docker: DB_HOST=db, для локального go run: DB_HOST=localhost)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=timemanager

# Если задан DB_HOST (в т.ч. в docker-compose), строка подключения собирается только из DB_* —
# DATABASE_URL из .env не используется (чтобы не подставлялся старый пароль).
# Без DB_HOST: используется DATABASE_URL, иначе postgres://...@localhost:...
# DATABASE_URL=postgres://postgres:postgres@localhost:5432/timemanager?sslmode=disable

# JWT (обязательно!)
JWT_SECRET=your-super-secret-key-min-32-chars

# Server
HTTP_PORT=8080
JWT_EXPIRES_MINUTES=60


# MinIO (для Docker: minio:9000, для локального go run: localhost:9000)
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=testik
MINIO_USE_SSL=false

# OAuth (Google, Yandex, GitHub)
OAUTH_REDIRECT_BASE=http://localhost:8080
OAUTH_FRONTEND_REDIRECT=http://localhost:3000/auth/callback
# OAUTH_GOOGLE_CLIENT_ID=
# OAUTH_GOOGLE_CLIENT_SECRET=
# OAUTH_YANDEX_CLIENT_ID=
# OAUTH_YANDEX_CLIENT_SECRET=
# OAUTH_GITHUB_CLIENT_ID=
# OAUTH_GITHUB_CLIENT_SECRET=
