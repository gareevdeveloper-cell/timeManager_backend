# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=testik

# Or use single URL:
# DATABASE_URL=postgres://postgres:postgres@localhost:5432/testik?sslmode=disable

# JWT (обязательно!)
JWT_SECRET=your-super-secret-key-min-32-chars

# Server
HTTP_PORT=8080
JWT_EXPIRES_MINUTES=60


# MinIO (docker compose: minio:9000; локальный go run: localhost:9000)
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=testik
MINIO_USE_SSL=false

# OAuth (Google, Yandex, GitHub)
OAUTH_REDIRECT_BASE=http://localhost:8080
OAUTH_FRONTEND_REDIRECT=http://localhost:3000/auth/callback
# OAUTH_GOOGLE_CLIENT_ID=
# OAUTH_GOOGLE_CLIENT_SECRET=
# OAUTH_YANDEX_CLIENT_ID=
# OAUTH_YANDEX_CLIENT_SECRET=
# OAUTH_GITHUB_CLIENT_ID=
# OAUTH_GITHUB_CLIENT_SECRET=
